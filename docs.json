                ]
              },
              "concepts/ai-agents/about"
            ]
          }
        ]
      },
      {
        "tab": "App Developers",
        "groups": [
          {
            "group": "Introduction",
            "pages": [
              "app/quickstart",
              "app/explaining-apps",
              "app/updating-apps",
              "app/deprecating-app-versions",
              "app/authenticating-users"
            ]
          }
        ]
      },
